        {
            "label": "Build nRF5 Lock App",
            "type": "shell",
            "command": "scripts/examples/nrf_example.sh examples/lock-app/nrf5 out/lock_app_debug",
            "group": "none",
            "dependsOn": "Generate",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Build nRF5 Lighting App",
            "type": "shell",
            "command": "scripts/examples/nrf_example.sh examples/lighting-app/nrf5 out/lighting_app_debug",
            "group": "none",
            "dependsOn": "Generate",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Build openSSL crypto Tests",
            "type": "shell",
            "command": "scripts/tests/openssl_tests.sh",
            "group": "none",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Build ESP32 Echo Example",
            "type": "shell",
            "command": "echo NOT supported yet - https://github.com/project-chip/connectedhomeip/issues/1510",
            "group": "none",
            "dependsOn": "Generate",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Build Standalone Echo Client",
            "type": "shell",
            "command": "scripts/examples/build_example.sh examples/chip-tool out/chip_tool_debug",
            "group": "none",
            "dependsOn": "Generate",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Build Standalone Shell",
            "type": "shell",
            "command": "scripts/examples/build_example.sh examples/shell out/shell_debug",
            "group": "none",
            "dependsOn": "Generate",
            "problemMatcher": ["$gcc"]
        }
    ]
